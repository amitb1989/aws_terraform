###############################################################
# 🚫 TERRAFORM: DO NOT COMMIT SYSTEM-GENERATED OR SENSITIVE FILES
###############################################################

# --- Terraform working directory ---
# Ignore all .terraform folders, including nested module paths
**/.terraform/

# Ignore Terraform lock file (optional but recommended to commit for version pinning)
# Uncomment if you want to EXCLUDE the lock file:
# .terraform.lock.hcl

# --- Terraform State Files ---
terraform.tfstate
terraform.tfstate.*
*.tfstate
*.tfstate.*

# --- Logs & diagnostic files ---
crash.log
crash.*.log
crash.out

# --- Terraform plan output files ---
*.tfplan
*.plan

# --- Sensitive variable files ---
terraform.tfvars
terraform.tfvars.json
*.tfvars
*.tfvars.json

# --- Terraform override files (local custom overrides) ---
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --- Local-only environment variable files ---
.env
.env.*

# --- Ignore editor + OS system files ---
# MacOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# VS Code settings
.vscode/

# PyCharm / IntelliJ
.idea/

# Git folder noise
.gitignore~